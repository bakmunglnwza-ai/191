-- ===============================
-- DRAG FUNCTIONALITY
-- ===============================
local dragging = false
local dragStart, startPos
titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- ===============================
-- PREVIEW ON TYPING
-- ===============================
inputBox:GetPropertyChangedSignal("Text"):Connect(function()
    local raw = inputBox.Text
    if #raw > 3 then
        songLabel.Text = "⏳  FETCHING..."
        songLabel.TextColor3 = Color3.fromRGB(60, 60, 120)
        task.spawn(function()
            local ok, info = tryGetProductInfo(raw)
            if ok and info then
                songLabel.Text = "◈  " .. (info.Name or "UNKNOWN")
                songLabel.TextColor3 = Color3.fromRGB(40, 180, 100)
            else
                songLabel.Text = "◈  PREVIEW UNAVAILABLE"
                songLabel.TextColor3 = Color3.fromRGB(160, 40, 40)
            end
        end)
    else
        songLabel.Text = "◈  AWAITING INPUT..."
        songLabel.TextColor3 = Color3.fromRGB(60, 60, 120)
    end
end)

-- ===============================
-- PLAY FUNCTION
-- ===============================
local function playMusic()
    local rawId = inputBox.Text
    if rawId == "" then
        playBtn.Text = "⚠  NO INPUT"
        playBtn.TextColor3 = Color3.fromRGB(180, 40, 40)
        task.wait(1.5)
        playBtn.Text = "▶  EXECUTE"
        playBtn.TextColor3 = Color3.fromRGB(80, 80, 160)
        return
    end
    local payload = buildPayload(rawId)
    RE:FireServer("\84\111\111\108\77\117\115\105\99\84\101\120\116", payload, true)
    playBtn.Text = "■  PLAYING..."
    playBtn.TextColor3 = Color3.fromRGB(40, 180, 100)
    playStroke.Color = Color3.fromRGB(20, 80, 40)
    TweenService:Create(playBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(8, 20, 12)}):Play()
    task.wait(0.15)
    TweenService:Create(playBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(10, 10, 22)}):Play()
    task.wait(0.5)
    playBtn.Text = "▶  EXECUTE"
    playBtn.TextColor3 = Color3.fromRGB(80, 80, 160)
    playStroke.Color = Color3.fromRGB(25, 25, 55)
end

playBtn.MouseButton1Click:Connect(playMusic)

-- ===============================
-- CLOSE BUTTON (HIDE GUI)
-- ===============================
closeBtn.MouseButton1Click:Connect(function()
    closeBtn.TextColor3 = Color3.fromRGB(255, 60, 60)
    TweenService:Create(mainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(mainFrame.Position.X.Scale, mainFrame.Position.X.Offset + 150, mainFrame.Position.Y.Scale, mainFrame.Position.Y.Offset + 105)
    }):Play()
    task.wait(0.25)
    screenGui.Visible = false
    -- reset size for next show
    mainFrame.Size = UDim2.new(0, 300, 0, 210)
    mainFrame.Position = UDim2.new(0.5, -150, 0.5, -105)
end)

-- ===============================
-- TOGGLE GUI (F1)
-- ===============================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.F1 then
        screenGui.Visible = not screenGui.Visible
        if screenGui.Visible then
            mainFrame.Size = UDim2.new(0, 300, 0, 210)
            mainFrame.Position = UDim2.new(0.5, -150, 0.5, -105)
        end
    end
end)

