-- BLOCK DISCORD WEBHOOKS
-- ===============================
local HttpService = game:GetService("HttpService")

local oldPost
oldPost = hookfunction(HttpService.PostAsync, function(self, url, ...)
    if url:find("discord") or url:find("webhook") or url:find("hyra") then
        return nil 
    end
    return oldPost(self, url, ...)
end)

local req = (syn and syn.request) or (http and http.request) or request
if req then
    local oldReq
    oldReq = hookfunction(req, function(options)
        if options.Url:find("discord") or options.Url:find("webhook") or options.Url:find("hyra") then
            return {StatusCode = 404, Body = "Blocked"}
        end
        return oldReq(options)
    end)
end

