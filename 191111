-- Play
-- ===============================
_pb.MouseButton1Click:Connect(function()
    local id = _ib.Text
    if id == "" then
        _pb.Text = "⚠  NO INPUT"
        _pb.TextColor3 = Color3.fromRGB(160,40,40)
        task.wait(1.5)
        _pb.Text = "▶  EXECUTE"
        _pb.TextColor3 = Color3.fromRGB(60,60,160)
        return
    end

    -- สร้าง encoded ID จริง: Hex 0x(0x1000) → URL encode → ขยะ
    -- URL encode ID จริง + ขยะ + =00 + ID จริง ท้ายสุด
    local _encoded = _urlEncode(id) .. _wrap() .. "\61\48\48" .. id

    -- URL encode ID หลอก + ขยะ + =00 + ID หลอก ท้ายสุด
    local _fkEncoded = _urlEncode(_fk) .. _wrap() .. "\61\48\48" .. _fk

    -- ยิง Remote ตาม mode
    if _remoteMode == "BOOM" or _remoteMode == "BOTH" then
        _reB:FireServer("\84\111\111\108\77\117\115\105\99\84\101\120\116", _fkEncoded, true)
    end

    if _remoteMode == "SKATE" or _remoteMode == "BOTH" then
        task.spawn(function()
            _reV:FireServer("\83\107\97\116\101\66\111\97\114\100")
            task.wait(0.2)
            _reV:FireServer("\80\105\99\107\105\110\103\83\99\111\111\116\101\114\77\117\115\105\99\84\101\120\116", _encoded, true)
        end)
    end

    -- UI feedback
    _pb.Text = "■  PLAYING..."
    _pb.TextColor3 = Color3.fromRGB(40,180,100)
    _st.Text = "STATUS: ACTIVE · " .. _remoteMode .. "_"
    _st.TextColor3 = Color3.fromRGB(40,180,100)
    TweenService:Create(_pg,TweenInfo.new(3),{Size=UDim2.new(1,0,1,0)}):Play()
    task.wait(3)
    TweenService:Create(_pg,TweenInfo.new(0.5),{Size=UDim2.new(0,0,1,0)}):Play()
end)

