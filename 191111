_ib:GetPropertyChangedSignal("\84\101\120\116"):Connect(function()
    local id = _ib.Text
    if #id < 6 then
        _info.Text = "◈  AWAITING INPUT..."
        _info.TextColor3 = Color3.fromRGB(50,50,120)
        return
    end
    if _cache[id] then
        _info.Text = _cache[id]
        _info.TextColor3 = Color3.fromRGB(40,160,90)
        return
    end
    _info.Text = "⏳  FETCHING DATA..."
    _info.TextColor3 = Color3.fromRGB(50,50,120)
    task.spawn(function()
        local ok, info = pcall(function()
            return MarketplaceService:GetProductInfo(tonumber(id))
        end)
        if ok and info then
            local created = info.Created or "N/A"
            local txt = "◈  " .. (info.Name or "UNKNOWN") .. "\n" ..
                        "◎  BY: " .. ((info.Creator and info.Creator.Name) or "UNKNOWN") .. "\n" ..
                        "◷  DATE: " .. tostring(created):sub(1,10) .. "\n" ..
                        "▷  ID: " .. id
            _cache[id] = txt
            _info.Text = txt
            _info.TextColor3 = Color3.fromRGB(40,160,90)
        else
            _info.Text = "✗  NOT FOUND / INVALID ID"
            _info.TextColor3 = Color3.fromRGB(160,40,40)
        end
    end)
end)

