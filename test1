-- PREVIEW ON TYPING
-- ===============================
inputBox:GetPropertyChangedSignal("Text"):Connect(function()
    local raw = inputBox.Text
    if #raw > 3 then
        songLabel.Text = "⏳  FETCHING..."
        songLabel.TextColor3 = Color3.fromRGB(60, 60, 120)
        task.spawn(function()
            local ok, info = tryGetProductInfo(raw)
            if ok and info then
                songLabel.Text = "◈  " .. (info.Name or "UNKNOWN")
                songLabel.TextColor3 = Color3.fromRGB(40, 180, 100)
            else
                songLabel.Text = "◈  PREVIEW UNAVAILABLE"
                songLabel.TextColor3 = Color3.fromRGB(160, 40, 40)
            end
        end)
    else
        songLabel.Text = "◈  AWAITING INPUT..."
        songLabel.TextColor3 = Color3.fromRGB(60, 60, 120)
    end
end)

-- ===============================
-- PLAY FUNCTION
-- ===============================
local function playMusic()
    local rawId = inputBox.Text
    if rawId == "" then
        task.spawn(function()
            playBtn.Text = "⚠  NO INPUT"
            playBtn.TextColor3 = Color3.fromRGB(180, 40, 40)
            task.wait(1.5)
            playBtn.Text = "▶  EXECUTE"
            playBtn.TextColor3 = Color3.fromRGB(80, 80, 160)
        end)
        return
    end

    local payload = buildPayload(rawId)
    sfxPlay:Play()

    -- ยิงทุกอย่างพร้อมกันเลย
    task.spawn(function()
        -- 1) สร้างสเกตก่อน
        RE2:FireServer("SkateBoard")
        task.wait(0.2)

        -- 2) ยิงรีโมทในสเกต
        RE2:FireServer("PickingScooterMusicText", payload, nil, true)
        
        -- 3) ยิงรีโมทบูมบ๊อก
        RE:FireServer("ToolMusicText", payload, nil, true)
        
        -- 4) ลบสเกต
        RE2:FireServer("Delete NoMotorVehicle")
    end)

    -- UI feedback
    task.spawn(function()
        playBtn.Text = "■  PLAYING..."
        playBtn.TextColor3 = Color3.fromRGB(40, 180, 100)
        playStroke.Color = Color3.fromRGB(20, 80, 40)
        TweenService:Create(playBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(8, 20, 12)}):Play()
        task.wait(0.15)
        TweenService:Create(playBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(10, 10, 22)}):Play()
        task.wait(0.8)
        playBtn.Text = "▶  EXECUTE"
        playBtn.TextColor3 = Color3.fromRGB(80, 80, 160)
        playStroke.Color = Color3.fromRGB(25, 25, 55)
    end)
end

playBtn.MouseButton1Click:Connect(playMusic)

