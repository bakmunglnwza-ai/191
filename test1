-- ===============================
-- DRAG TOGGLE BUTTON
-- แยก drag/click: ถ้าขยับเกิน 6px ถือว่า drag ไม่ใช่ click
-- ===============================
local draggingToggle = false
local toggleDragStart, toggleStartPos
local toggleDidDrag = false

toggleBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingToggle = true
        toggleDidDrag = false
        toggleDragStart = input.Position
        toggleStartPos = toggleBtn.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - toggleDragStart
        if math.abs(delta.X) > 6 or math.abs(delta.Y) > 6 then
            toggleDidDrag = true
        end
        if toggleDidDrag then
            toggleBtn.Position = UDim2.new(
                toggleStartPos.X.Scale, toggleStartPos.X.Offset + delta.X,
                toggleStartPos.Y.Scale, toggleStartPos.Y.Offset + delta.Y
            )
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingToggle = false
    end
end)

toggleBtn.MouseEnter:Connect(function()
    TweenService:Create(toggleBtn, TweenInfo.new(0.15), {
        BackgroundColor3 = Color3.fromRGB(20, 15, 45),
        ImageColor3 = Color3.fromRGB(130, 100, 255),
    }):Play()
    TweenService:Create(toggleStroke, TweenInfo.new(0.15), {Color = Color3.fromRGB(80, 60, 180)}):Play()
end)
toggleBtn.MouseLeave:Connect(function()
    TweenService:Create(toggleBtn, TweenInfo.new(0.15), {
        BackgroundColor3 = Color3.fromRGB(10, 10, 22),
        ImageColor3 = Color3.fromRGB(80, 80, 160),
    }):Play()
    TweenService:Create(toggleStroke, TweenInfo.new(0.15), {Color = Color3.fromRGB(40, 40, 90)}):Play()
end)
toggleBtn.MouseButton1Click:Connect(function()
    if toggleDidDrag then return end  -- ถ้าลากอยู่ไม่ต้องเปิด
    -- bounce กด
    TweenService:Create(toggleBtn, TweenInfo.new(0.08), {Size = UDim2.new(0, 68, 0, 68)}):Play()
    task.wait(0.08)
    openUI()
end)

