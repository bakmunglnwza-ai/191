-- ===============================
-- OPEN / CLOSE ANIMATIONS
-- ===============================
local isAnimating = false

local function openUI()
    if isAnimating then return end
    isAnimating = true

    -- ซ่อนปุ่ม toggle ก่อน
    toggleBtn.Visible = false
    sfxOpen:Play()

    -- เตรียม frame ก่อน animate
    mainFrame.Size = UDim2.new(0, 0, 0, 0)
    mainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
    mainFrame.Visible = true

    TweenService:Create(mainFrame, TweenInfo.new(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, FRAME_W, 0, FRAME_H),
        Position = CENTER_POS,
    }):Play()
    task.wait(0.28)

    -- pulse ขอบม่วง
    TweenService:Create(stroke, TweenInfo.new(0.15), {Color = Color3.fromRGB(80, 60, 180)}):Play()
    task.wait(0.2)
    TweenService:Create(stroke, TweenInfo.new(0.3), {Color = Color3.fromRGB(25, 25, 55)}):Play()

    isAnimating = false
end

local function closeUI()
    if isAnimating then return end
    isAnimating = true

    sfxClose:Play()
    -- animate ปิด UI
    TweenService:Create(mainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0.5, 0, 0.5, 0),
    }):Play()
    task.wait(0.22)
    mainFrame.Visible = false

    -- reset size สำหรับครั้งถัดไป
    mainFrame.Size = UDim2.new(0, FRAME_W, 0, FRAME_H)
    mainFrame.Position = CENTER_POS

    -- animate ปุ่ม toggle กลับมา (fade in เล็กน้อย)
    toggleBtn.Size = UDim2.new(0, 30, 0, 30)
    toggleBtn.Visible = true
    TweenService:Create(toggleBtn, TweenInfo.new(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0,50, 0, 50),
    }):Play()

    isAnimating = false
end

-- ===============================
-- DRAG FUNCTIONALITY
-- ===============================
local dragging = false
local dragStart, startPos
titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

