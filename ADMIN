local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local TextChatService = game:GetService("TextChatService")

-- [ รายชื่อกลุ่มแอดมิน ]
local AdminList = {
    [1697390697] = "OWNER",
    [9802544328] = "ADMIN",
    [6030349781] = "ADMIN",
    [10339491848] = "ADMIN"
}

local function IsAdmin(id) return AdminList[id] ~= nil end

-- ==========================================
-- 1. ระบบดักฟังคำสั่ง (ทำงานทุกเครื่อง)
-- ==========================================
local function RunCommand(cmd)
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not (char and hum and hrp) then return end

    if cmd == "!kill" then hum.Health = 0
    elseif cmd == "!kick" then LocalPlayer:Kick("191 System: Access Denied")
    elseif cmd == "!fly" then
        local bv = Instance.new("BodyVelocity", hrp)
        bv.Velocity = Vector3.new(0, 150, 0)
        bv.MaxForce = Vector3.new(0, math.huge, 0)
        task.wait(3) bv:Destroy()
    elseif cmd == "!boom" then
        Instance.new("Explosion", workspace).Position = hrp.Position
    elseif cmd == "!freeze" then hrp.Anchored = not hrp.Anchored
    elseif cmd == "!cage" then
        local p = Instance.new("Part", workspace)
        p.Size, p.CFrame, p.Anchored, p.Transparency = Vector3.new(6,8,6), hrp.CFrame, true, 0.5
        p.Color = Color3.new(0,0,0)
    elseif cmd == "!sit" then hum.Sit = true
    elseif cmd == "!fling" then
        local bV = Instance.new("BodyVelocity", hrp)
        bV.Velocity = Vector3.new(500000, 500000, 500000)
        bV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        local bA = Instance.new("BodyAngularVelocity", hrp)
        bA.AngularVelocity = Vector3.new(10000, 10000, 10000)
        bA.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        hum.PlatformStand = true
        task.wait(0.5) char:BreakJoints()
    end
end

-- ฟังก์ชันคัดกรองแชท
local function ProcessChat(message, senderId)
    if IsAdmin(senderId) then -- ถ้าคนที่พิมพ์เป็นแอดมิน
        local msgLower = message:lower()
        local args = string.split(msgLower, " ")
        local cmd = args[1]
        local targetName = args[2]
        
        -- ถ้าชื่อเป้าหมายมีอยู่ในชื่อเรา (พิมพ์แค่บางส่วนก็โดน)
        if targetName and string.find(LocalPlayer.Name:lower(), targetName) then
            RunCommand(cmd)
        end
    end
end

-- ดักฟังแชทระบบเก่า
for _, p in pairs(Players:GetPlayers()) do
    p.Chatted:Connect(function(msg) ProcessChat(msg, p.UserId) end)
end
Players.PlayerAdded:Connect(function(p)
    p.Chatted:Connect(function(msg) ProcessChat(msg, p.UserId) end)
end)

-- ดักฟังแชทระบบใหม่ (TextChatService)
if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
    TextChatService.MessageReceived:Connect(function(textChatMessage)
        if textChatMessage.TextSource then
            ProcessChat(textChatMessage.Text, textChatMessage.TextSource.UserId)
        end
    end)
end

-- ==========================================
-- 2. ระบบของแอดมิน (ป้าย + เมนู)
-- ==========================================
if IsAdmin(LocalPlayer.UserId) then
    
    -- ฟังก์ชันสร้างป้าย (จะรันในมุมมองของแอดมินเท่านั้น)
    local function ApplyTag(char, text, color)
        local head = char:WaitForChild("Head", 10)
        if not head then return end
        if head:FindFirstChild("Tag191") then head.Tag191:Destroy() end

        local bgui = Instance.new("BillboardGui", head)
        bgui.Name = "Tag191"
        bgui.Size = UDim2.new(0, 100, 0, 50)
        bgui.StudsOffset = Vector3.new(0, 3, 0)
        bgui.AlwaysOnTop = true
        
        local frame = Instance.new("Frame", bgui)
        frame.Size = UDim2.new(1, 0, 0.6, 0)
        frame.BackgroundColor3 = Color3.new(0, 0, 0)
        frame.BackgroundTransparency = 0.5
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
        
        local label = Instance.new("TextLabel", frame)
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = text
        label.TextColor3 = color
        label.TextSize = 18
        label.Font = Enum.Font.GothamBold
    end

    -- สั่งแปะป้ายทุกคนในเซิร์ฟ
    local function MonitorPlayers()
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character then
                ApplyTag(p.Character, IsAdmin(p.UserId) and AdminList[p.UserId] or "191", Color3.new(1,1,1))
            end
            p.CharacterAdded:Connect(function(char)
                ApplyTag(char, IsAdmin(p.UserId) and AdminList[p.UserId] or "191", Color3.new(1,1,1))
            end)
        end
    end
    MonitorPlayers()
    
    Players.PlayerAdded:Connect(function(p)
        p.CharacterAdded:Connect(function(char)
            ApplyTag(char, IsAdmin(p.UserId) and AdminList[p.UserId] or "191", Color3.new(1,1,1))
        end)
    end)

    -- โหลด UI เมนู
    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
    local Window = Rayfield:CreateWindow({ Name = "191 TEAM MASTER" })
    local MainTab = Window:CreateTab("Players", 4483362458)
    local Selected = ""

    local Dropdown = MainTab:CreateDropdown({
       Name = "Select Target",
       Options = {},
       Callback = function(Option) Selected = Option end,
    })

    local function Refresh()
        local list = {}
        for _, p in pairs(Players:GetPlayers()) do
            if not IsAdmin(p.UserId) then
                table.insert(list, p.Name)
            end
        end
        Dropdown:Set(list)
    end

    MainTab:CreateButton({ Name = "Refresh List", Callback = Refresh })

    local function Send(c)
        if Selected ~= "" then
            local fullMsg = c.." "..Selected
            
            -- พิมพ์แชทระบบเก่า
            local chatRemote = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
            if chatRemote and chatRemote:FindFirstChild("SayMessageRequest") then
                chatRemote.SayMessageRequest:FireServer(fullMsg, "All")
            end
            
            -- พิมพ์แชทระบบใหม่
            if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
                local channel = TextChatService:FindFirstChild("TextChannels") and TextChatService.TextChannels:FindFirstChild("RBXGeneral")
                if channel then channel:SendAsync(fullMsg) end
            end
        end
    end

    MainTab:CreateSection("Admin Commands")
    local cmds = {"!kill", "!kick", "!fly", "!boom", "!freeze", "!cage", "!sit", "!fling"}
    for _, v in pairs(cmds) do
        MainTab:CreateButton({ Name = v:sub(2):upper(), Callback = function() Send(v) end })
    end

    Refresh()
end

