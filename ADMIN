local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local TextChatService = game:GetService("TextChatService")
local Debris = game:GetService("Debris")

-- [ รายชื่อกลุ่มแอดมิน ]
local AdminList = {
    [1697390697] = "OWNER",
    [9802544328] = "ADMIN",
    [6030349781] = "ADMIN",
    [10339491848] = "ADMIN"
}

local function IsAdmin(id) return AdminList[id] ~= nil end
local VerifiedUsers = {}

-- ฟังก์ชันส่งข้อความแชท
local function MasterChat(msg)
    pcall(function()
        if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
            local channel = TextChatService:FindFirstChild("TextChannels") and TextChatService.TextChannels:FindFirstChild("RBXGeneral")
            if channel then channel:SendAsync(msg) end
        else
            local sayRemote = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
            if sayRemote and sayRemote:FindFirstChild("SayMessageRequest") then
                sayRemote.SayMessageRequest:FireServer(msg, "All")
            end
        end
    end)
end

-- ฟังก์ชันสร้างป้าย (จะถูกเรียกใช้เมื่อ Verified แล้วเท่านั้น)
local function ApplyTag(char, text, isVerified)
    local head = char:WaitForChild("Head", 10)
    if not head then return end
    if head:FindFirstChild("Tag191") then head.Tag191:Destroy() end
    
    -- สร้างป้ายเฉพาะตอนที่เป็น Verified หรือเป็นตัว Admin เอง
    if isVerified or IsAdmin(Players:GetPlayerFromCharacter(char).UserId) then
        local bgui = Instance.new("BillboardGui", head)
        bgui.Name = "Tag191"; bgui.Size = UDim2.new(0,100,0,50); bgui.StudsOffset = Vector3.new(0,3,0); bgui.AlwaysOnTop = true
        
        local frame = Instance.new("Frame", bgui); frame.Size = UDim2.new(1.2,0,0.6,0); frame.BackgroundColor3 = Color3.new(0,0,0); frame.BackgroundTransparency = 0.4
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0,8)
        
        local l = Instance.new("TextLabel", frame); l.Size = UDim2.new(1,0,1,0); l.BackgroundTransparency = 1; l.Text = text; l.TextSize = 14; l.Font = Enum.Font.GothamBold
        
        if isVerified then
            l.TextColor3 = Color3.fromRGB(0, 255, 127) -- สีเขียว
            l.Text = "[Verified] 191-ACTIVE"
        else
            l.TextColor3 = Color3.new(1,1,1) -- สีขาว (สำหรับแอดมิน)
            l.Text = text
        end
    end
end

-- ระบบคัดกรองแชท
local function ProcessChat(message, senderId)
    local msg = message:lower()
    
    -- ระบบรายงานตัว (แอดมินสั่ง !Verified191 ลูกน้องตอบ !191)
    if msg == "!verified191" and not IsAdmin(LocalPlayer.UserId) then
        MasterChat("!191")
    end
    
    if msg == "!191" and IsAdmin(LocalPlayer.UserId) then
        local sender = Players:GetPlayerByUserId(senderId)
        if sender and sender.Character then
            VerifiedUsers[senderId] = true
            ApplyTag(sender.Character, "191-ACTIVE", true) -- แปะป้ายเขียวเมื่อรายงานตัวสำเร็จ
        end
    end

    -- ระบบคำสั่งแอดมิน
    if IsAdmin(senderId) then
        local args = string.split(msg, " ")
        if args[1] and args[2] and string.find(LocalPlayer.Name:lower(), args[2]) then
            local cmd = args[1]
            local char = LocalPlayer.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if not (char and hum and hrp) then return end

            if cmd == "!kill" then hum.Health = 0
            elseif cmd == "!fling" then
                local bV = Instance.new("BodyVelocity", hrp); bV.Velocity = Vector3.new(500000, 500000, 500000); bV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                local bA = Instance.new("BodyAngularVelocity", hrp); bA.AngularVelocity = Vector3.new(10000, 10000, 10000); bA.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                hum.PlatformStand = true; task.wait(0.5); char:BreakJoints()
            end
        end
    end
end

-- ดักฟังแชท
if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
    TextChatService.MessageReceived:Connect(function(m) if m.TextSource then ProcessChat(m.Text, m.TextSource.UserId) end end)
else
    for _, p in pairs(Players:GetPlayers()) do p.Chatted:Connect(function(m) ProcessChat(m, p.UserId) end) end
    Players.PlayerAdded:Connect(function(p) p.Chatted:Connect(function(m) ProcessChat(m, p.UserId) end) end)
end

-- [[ ส่วนของแอดมิน (UI) ]]
if IsAdmin(LocalPlayer.UserId) then
    -- แปะป้ายเฉพาะกลุ่มแอดมินด้วยกันเองก่อน
    local function CheckAdmins()
        for _, p in pairs(Players:GetPlayers()) do
            if IsAdmin(p.UserId) and p.Character then
                ApplyTag(p.Character, AdminList[p.UserId], false)
            end
        end
    end
    CheckAdmins()
    Players.PlayerAdded:Connect(function(p) p.CharacterAdded:Connect(function(c) if IsAdmin(p.UserId) then ApplyTag(c, AdminList[p.UserId], false) end end) end)

    -- โหลด Rayfield UI
    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
    local Window = Rayfield:CreateWindow({ Name = "191 MASTER (No Tags Mode)" })
    local MainTab = Window:CreateTab("Control", 4483362458)
    
    MainTab:CreateButton({ 
        Name = "VERIFY ALL (TAG ONLY ACTIVE)", 
        Callback = function() MasterChat("!Verified191") end 
    })

    local Selected = ""
    local Dropdown = MainTab:CreateDropdown({ Name = "Target", Options = {}, Callback = function(o) Selected = o end })
    
    MainTab:CreateButton({ Name = "Refresh List", Callback = function()
        local list = {}
        for _, p in pairs(Players:GetPlayers()) do if not IsAdmin(p.UserId) then table.insert(list, p.Name) end end
        Dropdown:Set(list)
    end})

    MainTab:CreateSection("Commands")
    local function MasterSend(cmd) if Selected ~= "" then MasterChat(cmd.." "..Selected) end end
    local cmds = {"!kill", "!fling", "!boom", "!freeze"}
    for _, v in pairs(cmds) do
        MainTab:CreateButton({ Name = v:sub(2):upper(), Callback = function() MasterSend(v) end })
    end
end

