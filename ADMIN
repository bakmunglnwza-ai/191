local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local TextChatService = game:GetService("TextChatService")
local Debris = game:GetService("Debris")

-- [ รายชื่อกลุ่มแอดมิน ]
local AdminList = {
    [1697390697] = "OWNER",
    [9802544328] = "ADMIN",
    [6030349781] = "ADMIN",
    [10339491848] = "ADMIN"
}

local function IsAdmin(id) return AdminList[id] ~= nil end
local VerifiedUsers = {}

-- ฟังก์ชันส่งข้อความแชท
local function MasterChat(msg)
    pcall(function()
        if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
            local channel = TextChatService:FindFirstChild("TextChannels") and TextChatService.TextChannels:FindFirstChild("RBXGeneral")
            if channel then channel:SendAsync(msg) end
        else
            local sayRemote = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
            if sayRemote and sayRemote:FindFirstChild("SayMessageRequest") then
                sayRemote.SayMessageRequest:FireServer(msg, "All")
            end
        end
    end)
end

-- ฟังก์ชันสร้างป้าย
local function ApplyTag(char, text, isVerified)
    local head = char:WaitForChild("Head", 10)
    if not head then return end
    if head:FindFirstChild("Tag191") then head.Tag191:Destroy() end
    
    if isVerified or IsAdmin(Players:GetPlayerFromCharacter(char).UserId) then
        local bgui = Instance.new("BillboardGui", head)
        bgui.Name = "Tag191"; bgui.Size = UDim2.new(0,100,0,50); bgui.StudsOffset = Vector3.new(0,3,0); bgui.AlwaysOnTop = true
        
        local frame = Instance.new("Frame", bgui); frame.Size = UDim2.new(1.2,0,0.6,0); frame.BackgroundColor3 = Color3.new(0,0,0); frame.BackgroundTransparency = 0.4
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0,8)
        
        local l = Instance.new("TextLabel", frame); l.Size = UDim2.new(1,0,1,0); l.BackgroundTransparency = 1; l.Text = text; l.TextSize = 14; l.Font = Enum.Font.GothamBold
        
        if isVerified then
            l.TextColor3 = Color3.fromRGB(0, 255, 127)
            l.Text = "[Verified] 191-ACTIVE"
        else
            l.TextColor3 = Color3.new(1,1,1)
            l.Text = text
        end
    end
end

-- ระบบคัดกรองแชท
local function ProcessChat(message, senderId)
    local msg = message:lower()
    
    -- ระบบรายงานตัว
    if msg == "!verified191" and not IsAdmin(LocalPlayer.UserId) then
        MasterChat("!191")
    end
    
    if msg == "!191" and IsAdmin(LocalPlayer.UserId) then
        local sender = Players:GetPlayerByUserId(senderId)
        if sender and sender.Character then
            VerifiedUsers[senderId] = true
            ApplyTag(sender.Character, "191-ACTIVE", true)
        end
    end

    -- ระบบคำสั่งแอดมิน
    if IsAdmin(senderId) then
        local args = string.split(msg, " ")
        if args[1] and args[2] and string.find(LocalPlayer.Name:lower(), args[2]) then
            local cmd = args[1]
            local char = LocalPlayer.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if not (char and hum and hrp) then return end

            if cmd == "!kill" or cmd == "!ฆ่า" then 
                hum.Health = 0
                
            elseif cmd == "!fling" or cmd == "!เหวี่ยง" then
                local bV = Instance.new("BodyVelocity", hrp); 
                bV.Velocity = Vector3.new(500000, 500000, 500000); 
                bV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                local bA = Instance.new("BodyAngularVelocity", hrp); 
                bA.AngularVelocity = Vector3.new(10000, 10000, 10000); 
                bA.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                hum.PlatformStand = true; 
                task.wait(0.5); 
                char:BreakJoints()
                
            elseif cmd == "!kick" or cmd == "!เตะ" then
                LocalPlayer:Kick("คุณถูกเตะโดยแอดมิน | Kicked by Admin")
                
            elseif cmd == "!tp" or cmd == "!วาป" then
                -- วาปไปหาแอดมินที่พิมพ์คำสั่ง
                local admin = Players:GetPlayerByUserId(senderId)
                if admin and admin.Character and admin.Character:FindFirstChild("HumanoidRootPart") then
                    hrp.CFrame = admin.Character.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
                end
                
            elseif cmd == "!freeze" or cmd == "!แข็ง" then
                hum.PlatformStand = true
                hum.WalkSpeed = 0
                hum.JumpPower = 0
                
            elseif cmd == "!unfreeze" or cmd == "!หายแข็ง" then
                hum.PlatformStand = false
                hum.WalkSpeed = 16
                hum.JumpPower = 50
                
            elseif cmd == "!boom" or cmd == "!ระเบิด" then
                local explosion = Instance.new("Explosion", hrp)
                explosion.BlastRadius = 10
                explosion.BlastPressure = 500000
                explosion.Position = hrp.Position
                
            elseif cmd == "!jail" or cmd == "!ขัง" then
                -- สร้างกรอบขัง (กล่องสี่เหลี่ยม)
                local jail = Instance.new("Part")
                jail.Name = "Jail191"
                jail.Size = Vector3.new(10, 10, 10)
                jail.CFrame = hrp.CFrame
                jail.Anchored = true
                jail.Transparency = 0.5
                jail.Color = Color3.fromRGB(255, 0, 0)
                jail.Material = Enum.Material.Neon
                jail.Parent = workspace
                
                -- สร้างหลังคา
                local roof = Instance.new("Part")
                roof.Size = Vector3.new(10, 1, 10)
                roof.CFrame = hrp.CFrame + Vector3.new(0, 5, 0)
                roof.Anchored = true
                roof.Transparency = 0.5
                roof.Color = Color3.fromRGB(255, 0, 0)
                roof.Material = Enum.Material.Neon
                roof.Parent = workspace
                
                -- สร้างพื้น
                local floor = Instance.new("Part")
                floor.Size = Vector3.new(10, 1, 10)
                floor.CFrame = hrp.CFrame - Vector3.new(0, 5, 0)
                floor.Anchored = true
                floor.Transparency = 0.5
                floor.Color = Color3.fromRGB(255, 0, 0)
                floor.Material = Enum.Material.Neon
                floor.Parent = workspace
                
                -- ลบกรอบขังหลัง 30 วิ
                task.wait(30)
                jail:Destroy()
                roof:Destroy()
                floor:Destroy()
            end
        end
    end
end

-- ดักฟังแชท
if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
    TextChatService.MessageReceived:Connect(function(m) if m.TextSource then ProcessChat(m.Text, m.TextSource.UserId) end end)
else
    for _, p in pairs(Players:GetPlayers()) do p.Chatted:Connect(function(m) ProcessChat(m, p.UserId) end) end
    Players.PlayerAdded:Connect(function(p) p.Chatted:Connect(function(m) ProcessChat(m, p.UserId) end) end)
end

