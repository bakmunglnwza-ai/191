local function tryGetProductInfo(input)
    local num = tonumber(input)
    if not num and string.sub(input, 1, 2):lower() == "0x" then
        num = tonumber(input)
    end
    if not num then
        return nil, "Invalid ID"
    end
    return pcall(function()
        return MarketplaceService:GetProductInfo(num)
    end)
end

