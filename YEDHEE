-- สแกน
local function Scan()
    ScanBtn.Text = "⏳ กำลังสแกน..."
    ScanBtn.Interactable = false
    ClearList()

    task.spawn(function()
        local seen = {}
        local count = 0
        local all = game:GetDescendants()
        for _, obj in ipairs(all) do
            if obj:IsA("AudioPlayer") and obj.SoundId ~= "" and not seen[obj] then
                seen[obj] = true
                local id = GetID(obj.SoundId)
                if id then
                    count = count + 1
                    local owner = FindOwner(obj)
                    local device = obj.Parent and obj.Parent.Name or "?"
                    print("[191] พบ: "..owner.." - "..device.." | ID: "..id)

                    -- ดึงข้อมูลจาก Marketplace
                    local info = nil
                    pcall(function()
                        info = MarketplaceService:GetProductInfo(tonumber(id))
                    end)
                    CreateCard(obj, owner, device, info)
                end
            end
        end
        if count == 0 then
            local lbl = Instance.new("TextLabel")
            lbl.Text = "ไม่พบ AudioPlayer ในเซิร์ฟเวอร์"
            lbl.Size = UDim2.new(1,0,0,30)
            lbl.BackgroundTransparency = 1
            lbl.TextColor3 = C.Dim
            lbl.Font = Enum.Font.Gotham
            lbl.TextSize = 13
            lbl.Parent = List
        end
        ScanBtn.Text = "🔍 สแกน"
        ScanBtn.Interactable = true
        print("[191] สแกนเสร็จ พบ "..count.." รายการ")
    end)
end
ScanBtn.MouseButton1Click:Connect(Scan)

