-- Helper: ดึง ID
local function GetID(soundId)
    return soundId:match("rbxassetid://(%d+)") or soundId:match("rbxsestid://(%d+)") or soundId:match("(%d+)$")
end

-- Helper: หาเจ้าของจาก AudioPlayer
local function FindOwner(obj)
    -- 1. ถ้าอยู่ใต้ Character
    local cur = obj
    while cur and cur.Parent do
        if cur:IsA("Model") then
            local plr = Players:GetPlayerFromCharacter(cur)
            if plr then return plr.Name end
        end
        cur = cur.Parent
    end
    -- 2. จากชื่อ Parent (เช่น RELICSxyz Boombox)
    local parentName = obj.Parent and obj.Parent.Name or ""
    for _, plr in ipairs(Players:GetPlayers()) do
        if parentName:find(plr.Name, 1, true) then
            return plr.Name
        end
    end
    return "Server/Ambient"
end

