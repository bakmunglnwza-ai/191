-- // 11. Scan Function (Workspace + Players) //
local function ScanAllAudioPlayers()
    local found = {}
    
    -- สร้าง mapping Character -> Player
    local playerCharMap = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then
            playerCharMap[plr.Character] = plr
        end
    end
    
    -- รายการที่ต้องการสแกน (เพิ่ม Workspace และ Player ทุกคน)
    local searchContainers = {Workspace}
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then
            table.insert(searchContainers, plr.Character)
        end
        local pg = plr:FindFirstChild("PlayerGui")
        if pg then
            table.insert(searchContainers, pg)
        end
    end
    
    -- ใช้ Set เพื่อป้องกันการซ้ำของ AudioPlayer ตัวเดียวกัน (ถ้าอยู่ภายใต้หลาย container)
    local seen = {}
    
    for _, container in ipairs(searchContainers) do
        pcall(function()
            for _, obj in ipairs(container:GetDescendants()) do
                if obj:IsA("AudioPlayer") and obj.SoundId ~= "" then
                    if seen[obj] then continue end
                    seen[obj] = true
                    
                    local cleanID = obj.SoundId:match("%d+")
                    if cleanID and #cleanID > 3 then
                        local deviceName = GetDeviceName(obj)
                        local owner = FindOwnerPlayer(obj)
                        local ownerName = owner and owner.Name or "Server/Ambient"
                        
                        table.insert(found, {
                            ownerName = ownerName,
                            audio = obj,
                            device = deviceName
                        })
                    end
                end
            end
        end)
    end
    
    return found
end

-- // 12. Refresh Display //
local function PerformScan()
    ScanBtn.Interactable = false
    ScanBtn.Text = "⏳ กำลังสแกน..."
    
    ClearSongList()
    
    task.spawn(function()
        local audioPlayers = ScanAllAudioPlayers()
        
        print("[191] Found " .. #audioPlayers .. " AudioPlayer(s).")
        
        if #audioPlayers == 0 then
            local emptyLabel = Instance.new("TextLabel")
            emptyLabel.Text = "ไม่พบ AudioPlayer ในเซิร์ฟเวอร์"
            emptyLabel.Size = UDim2.new(1, 0, 0, 30)
            emptyLabel.BackgroundTransparency = 1
            emptyLabel.TextColor3 = COLORS.TextDim
            emptyLabel.Font = Enum.Font.Gotham
            emptyLabel.TextSize = 14
            emptyLabel.Parent = ListContainer
        else
            for _, data in ipairs(audioPlayers) do
                local audio = data.audio
                local owner = data.ownerName
                local device = data.device
                local assetId = tonumber(audio.SoundId:match("%d+"))
                
                if assetId then
                    local success, info = pcall(function()
                        return MarketplaceService:GetProductInfo(assetId)
                    end)
                    if success and info then
                        CreateMusicCard(audio, info, owner, device)
                    else
                        CreateMusicCard(audio, {Name = "ไม่สามารถดึงข้อมูล", Creator = {Name = "-"}}, owner, device)
                    end
                end
            end
        end
        
        ScanBtn.Interactable = true
        ScanBtn.Text = "🔍 สแกนเพลง"
    end)
end

ScanBtn.MouseButton1Click:Connect(PerformScan)

-- // 13. Drag Functionality //
local dragging, dragInput, dragStart, startPos

local function updateDrag(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

Header.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        updateDrag(input)
    end
end)

