-- ======================== ระบบ RGB & REAL-TIME SYNC (เดิม) ========================
task.spawn(function()
    local bars = {" ", " ", "▂", "▃", "▄", "▅", "▆", "▇", "█"}
    while true do
        local color = Color3.fromHSV(tick() % 5 / 5, 1, 1)
        pcall(function() game:GetService("CoreGui").Rayfield.Main.Elements.BackgroundColor3 = color end)
        
        if IsPlaying and SongDuration > 0 then
            local elapsed = math.floor(tick() - StartTime)
            if elapsed <= SongDuration then
                TimeLabel:Set("⏳ เวลาเล่น: " .. FormatTime(elapsed) .. " / " .. FormatTime(SongDuration))
                local v = ""
                for i = 1, 14 do
                    local loudness = (VisualSound and VisualSound.PlaybackLoudness) or 0
                    local scale = math.clamp(math.floor(loudness / 40) + math.random(-1,1), 1, #bars)
                    v = v .. bars[scale]
                end
                VisualLabel:Set("🔊 [ " .. v .. " ]")
            else
                IsPlaying = false
                TimeLabel:Set("⏳ จบเพลง")
            end
        end
        task.wait(0.05)
    end
end)
