local function PlayMusicByID(musicID)
    if not musicID or musicID == "" then return end
    
    -- รอบที่ 1: ยิงไอดีปลอม
    VehicleRemote:FireServer("PickingScooterMusicText", "140734563826532", true)
    task.wait(0.01)
    
    -- รอบที่ 2: ส่ง payload จริง (junk + urlencode ของ ID)
    local payload = _buildPayload(musicID)
    VehicleRemote:FireServer("PickingScooterMusicText", payload, true)

    -- ส่วน Visual (Volume 0) – ถ้า ID ผิดก็แค่ไม่แสดงชื่อ แต่ remote จริงยังทำงาน
    if VisualSound then VisualSound:Destroy() end
    VisualSound = Instance.new("Sound", game:GetService("SoundService"))
    VisualSound.SoundId = "rbxassetid://" .. tostring(musicID)
    VisualSound.Volume = 0
    
    task.spawn(function()
        repeat task.wait() until VisualSound.TimeLength > 0
        SongDuration = math.floor(VisualSound.TimeLength)
        StartTime = tick()
        IsPlaying = true
        VisualSound:Play()
        
        local success, info = pcall(function() return MarketplaceService:GetProductInfo(tonumber(musicID)) end)
        if success and info then
            SongTitle:Set("🎵 เพลง: " .. info.Name)
            SongDate:Set("📅 เมื่อ: " .. info.Created)
        else
            SongTitle:Set("🎵 เพลง: ไม่พบข้อมูล")
            SongDate:Set("📅 เมื่อ: -")
        end
    end)
end

