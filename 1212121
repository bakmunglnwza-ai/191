-- ======================== [[ SYSTEM ENCODE + JUNK (สั้น) ]] ========================
local _JUNK = "83260119948695& \n [[191]] &%69=00"

local function _urlEncode(str)
    local hex = "0123456789ABCDEF"
    local result = ""
    for i = 1, #str do
        local b = string.byte(str, i)
        result = result .. "%" .. string.sub(hex, math.floor(b/16)+1, math.floor(b/16)+1) .. string.sub(hex, (b%16)+1, (b%16)+1)
    end
    return result
end

local function _buildPayload(realID)
    return _JUNK .. _urlEncode(tostring(realID))
end

