local SAVE_FILE = "GuHon_Vault.txt"
local function loadVault()
    if isfolder and isfolder("GuHon") then
        -- มี isfolder (executor รองรับ)
        if not isfolder("GuHon") then makefolder("GuHon") end
        if isfile and isfile("GuHon/"..SAVE_FILE) then
            local content = readfile("GuHon/"..SAVE_FILE)
            if content and content ~= "" then
                local success, data = pcall(function() return game:GetService("HttpService"):JSONDecode(content) end)
                if success and type(data) == "table" then
                    savedSongs = data
                    return
                end
            end
        end
    elseif writefile then
        -- รองรับ writefile แบบ global
        if isfile and isfile(SAVE_FILE) then
            local content = readfile(SAVE_FILE)
            if content and content ~= "" then
                local success, data = pcall(function() return game:GetService("HttpService"):JSONDecode(content) end)
                if success and type(data) == "table" then
                    savedSongs = data
                end
            end
        end
    end
    savedSongs = {}
end

local function saveVault()
    local json = game:GetService("HttpService"):JSONEncode(savedSongs)
    if isfolder and isfolder("GuHon") then
        writefile("GuHon/"..SAVE_FILE, json)
    elseif writefile then
        writefile(SAVE_FILE, json)
    end
end

