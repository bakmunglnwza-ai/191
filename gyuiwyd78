		db.MouseLeave:Connect(function() db.TextColor3=C.TEXT_DIM; db:FindFirstChildOfClass("UIStroke").Color=C.BORDER end)
		local ci = i
		db.MouseButton1Click:Connect(function()
			table.remove(savedList,ci); renderSaved()
		end)
	end
end

local function onAddPressed()
	local name = (nameIn.Text:match("^%s*(.-)%s*$") or "")
	local id   = saveIdIn.Text:gsub("%D","")
	if id=="" then return end
	if name=="" then name="UNTITLED" end
	table.insert(savedList,{name=name,id=id})
	nameIn.Text=""; saveIdIn.Text=""
	renderSaved()
end

addBtn.MouseButton1Click:Connect(onAddPressed)
saveIdIn.FocusLost:Connect(function(e) if e then onAddPressed() end end)
renderSaved()

