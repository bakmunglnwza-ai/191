-- WAVEFORM + AUDIO LOGIC  (FIXED)
-- ══════════════════════════════════════
math.randomseed(12345)
local barProfile = {}
for i = 1, BAR_N do
	local center = 1 - math.abs((i - BAR_N/2) / (BAR_N/2))
	barProfile[i] = {
		speed = 6  + math.random() * 14,
		scale = 0.4 + center * 0.8 + math.random() * 0.3,
		phase = math.random() * math.pi * 2,
		drift = 0.5 + math.random() * 1.5,
	}
end

local barVal = {}
for i = 1, BAR_N do barVal[i] = 0.04 end

local isPlaying  = false
local isLoading  = false
local hasFiredStop = false
local progConn   = nil
local progVal    = 0
local totalSec   = 180
local currentId  = ""
local sound      = nil

-- idle breathe
RunService.Heartbeat:Connect(function()
	if isPlaying then return end
	local t = tick()
	for i = 1, BAR_N do
		local v = 0.03 + math.sin(t*1.1 + i*0.35)*0.02
		barVal[i] = barVal[i] + (v - barVal[i]) * 0.1
		wBars[i].Size = UDim2.new(1/BAR_N-0.004, 0, barVal[i], 0)
		wBars[i].BackgroundColor3 = C.PURPLE
	end
end)

-- playing wave  (FIX: read loudness from the same sound object)
RunService.Heartbeat:Connect(function(dt)
	if not isPlaying then return end
	local loud = (sound and sound.Playing) and sound.PlaybackLoudness or 0
	local base = math.clamp(loud / 1000, 0, 1)
	local t = tick()
	for i = 1, BAR_N do
		local p = barProfile[i]
		local drift = math.sin(t * p.drift + p.phase) * 0.07 * base
		local target = math.clamp(base * p.scale + drift, 0.03, 0.96)
		barVal[i] = barVal[i] + (target - barVal[i]) * math.min(1, dt * p.speed)
		local val = barVal[i]
		wBars[i].Size = UDim2.new(1/BAR_N-0.004, 0, val, 0)
		local r  = (124 + val*100) / 255
		local g  = (58  + val*20)  / 255
		local bv = (237 - val*60)  / 255
		wBars[i].BackgroundColor3 = Color3.new(r, g, bv)
	end
end)

local function stopPlay()
	if hasFiredStop then return end
	hasFiredStop = true
	isPlaying = false
	playBtn.Text = "▶"
	playBtn.BackgroundColor3 = C.PURPLE
	playBtn:FindFirstChildOfClass("UIStroke").Color = C.PUR_LT
	statusLbl.Text = "PAUSED"
	if sound then sound:Pause() end
	if progConn then progConn:Disconnect(); progConn = nil end
	fireAudioRemote("84899763517255")
	fireAudioRemote("0")
end

-- FIX: startPlay — guard against nil sound, resume correctly
local function startPlay()
	if not sound then return end
	hasFiredStop = false
	isPlaying = true
	playBtn.Text = "⏸"
	playBtn.BackgroundColor3 = C.RED
	playBtn:FindFirstChildOfClass("UIStroke").Color = Color3.fromHex("F87171")
	statusLbl.Text = "PLAYING"

	-- FIX: Resume if already started, else Play from beginning
	if sound.TimePosition > 0 and not sound.Playing then
		sound:Resume()
	elseif not sound.Playing then
		sound:Play()
	end

	-- FIX: disconnect old progConn before creating a new one
	if progConn then progConn:Disconnect(); progConn = nil end

	progConn = RunService.Heartbeat:Connect(function(dt)
		if not isPlaying then return end
		if sound and sound.IsPlaying then
			progVal = math.clamp(sound.TimePosition / totalSec, 0, 1)
			timeLbl.Text = math.floor(sound.TimePosition).."s / "..totalSec.."s"
		else
			progVal = math.min(1, progVal + dt / totalSec)
			timeLbl.Text = math.floor(progVal * totalSec).."s / "..totalSec.."s"
		end
		progFill.Size = UDim2.new(progVal, 0, 1, 0)
		if progVal >= 1 then
			stopPlay()
			statusLbl.Text = "DONE"
			progVal = 0
		end
	end)

	-- Signal server: play this ID
	fireAudioRemote(currentId)
end

local function onPlayPressed()
	if isLoading then return end  -- FIX: block double-press while loading

	local raw = idInput.Text:gsub("%D","")

	if raw ~= "" and raw ~= currentId then
		-- New ID — load fresh sound
		currentId = raw
		progVal = 0
		progFill.Size = UDim2.new(0,0,1,0)
		timeLbl.Text = "0s / 0s"
		for i=1,BAR_N do barVal[i]=0.04 end

		-- FIX: stop & clean up previous sound before creating a new one
		if isPlaying then stopPlay() end
		if sound then sound:Destroy(); sound = nil end

		isLoading = true
		statusLbl.Text = "LOADING..."
		playBtn.BackgroundColor3 = C.BG_DEEP
		playBtn.Text = "…"

		local newSound = Instance.new("Sound")
		newSound.SoundId = "rbxassetid://" .. raw
		newSound.Volume  = 0
		newSound.Parent  = playPage
		sound = newSound

		-- FIX: wait for the correct sound instance to load
		newSound.Loaded:Connect(function()
			-- Guard: user may have changed ID again while this was loading
			if sound ~= newSound then return end

			isLoading = false
			totalSec  = math.max(1, math.floor(newSound.TimeLength))
			timeLbl.Text = "0s / " .. totalSec .. "s"
			statusLbl.Text = "LOADED"
			playBtn.BackgroundColor3 = C.PURPLE
			playBtn.Text = "▶"
			startPlay()
		end)

	elseif raw == "" then
		-- No ID typed — do nothing
		return

	else
		-- Same ID — toggle play/pause
		if isPlaying then
			stopPlay()
		else
			startPlay()
		end
	end
end

playBtn.MouseButton1Click:Connect(onPlayPressed)

idInput.FocusLost:Connect(function(enter)
	if enter then onPlayPressed() end
end)

