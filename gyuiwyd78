-- ══════════════════════════════════════
local toggleBtn = new("TextButton", {
	Size            = UDim2.fromOffset(48, 48),
	Position        = UDim2.new(1, -60, 1, -60),
	BackgroundColor3 = C.PURPLE,
	BorderSizePixel  = 0,
	Text            = "♪",
	TextColor3      = C.WHITE,
	TextSize        = 22,
	Font            = Enum.Font.Code,
	AutoButtonColor = false,
	ZIndex          = 10,
}, sg)
corner(12, toggleBtn)
stroke(C.PUR_LT, 1.5, toggleBtn)

TweenService:Create(toggleBtn:FindFirstChildOfClass("UIStroke"),
	TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
	{Color = C.PURPLE}):Play()

local _tbDrag, _tbStart, _tbOrigin = false
local _wasDragged = false

toggleBtn.InputBegan:Connect(function(i)
	if i.UserInputType == Enum.UserInputType.MouseButton1
	or i.UserInputType == Enum.UserInputType.Touch then
		_tbDrag     = true
		_wasDragged = false
		_tbStart    = i.Position
		_tbOrigin   = toggleBtn.Position
	end
end)
toggleBtn.InputEnded:Connect(function(i)
	if i.UserInputType == Enum.UserInputType.MouseButton1
	or i.UserInputType == Enum.UserInputType.Touch then
		_tbDrag = false
	end
end)
UIS.InputChanged:Connect(function(i)
	if not _tbDrag then return end
	if i.UserInputType == Enum.UserInputType.MouseMovement
	or i.UserInputType == Enum.UserInputType.Touch then
		local delta = i.Position - _tbStart
		if delta.Magnitude > 4 then _wasDragged = true end
		toggleBtn.Position = UDim2.new(
			_tbOrigin.X.Scale, _tbOrigin.X.Offset + delta.X,
			_tbOrigin.Y.Scale, _tbOrigin.Y.Offset + delta.Y
		)
	end
end)

local guiOpen = true
local _mainTween, _hideTask

toggleBtn.MouseButton1Click:Connect(function()
	if _wasDragged then return end
	if _mainTween then _mainTween:Cancel() end
	if _hideTask  then task.cancel(_hideTask) end
	guiOpen = not guiOpen
	local targetPos = guiOpen
		and UDim2.new(0.5,-W/2, 1,-H-8)
		or  UDim2.new(0.5,-W/2, 1, 8)
	main.Visible = true
	_mainTween = TweenService:Create(main,
		TweenInfo.new(0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
		{Position = targetPos})
	_mainTween:Play()
	if not guiOpen then
		_hideTask = task.delay(0.3, function()
			if not guiOpen then main.Visible = false end
		end)
	end
	TweenService:Create(toggleBtn, TweenInfo.new(0.15),
		{BackgroundColor3 = guiOpen and C.PURPLE or C.BG_DEEP}):Play()
	toggleBtn.Text = guiOpen and "♪" or "×"
end)

