local tabs = {}
local tabBtns = {}
local activeTab = nil
local C_WHITE = Color3.fromRGB(255, 255, 255)
local C_DIM = Color3.fromRGB(60, 60, 60)

local function SwitchTab(name)
    for n, page in pairs(tabs) do
        page.Visible = (n == name)
    end
    for n, btn in pairs(tabBtns) do
        if n == name then
            btn.TextColor3 = C_WHITE
            btn.BorderSizePixel = 0
            if btn:FindFirstChild("Underline") then
                btn.Underline.BackgroundColor3 = C_WHITE
            end
        else
            btn.TextColor3 = C_DIM
            if btn:FindFirstChild("Underline") then
                btn.Underline.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
            end
        end
    end
    activeTab = name
end

local function AddTab(name, label)
    local btn = NewButton({
        Name = name .. "Btn",
        Size = UDim2.new(0.5, 0, 1, 0),
        BackgroundColor3 = Color3.fromRGB(6, 6, 6),
        BorderSizePixel = 0,
        Text = label,
        TextColor3 = C_DIM,
        TextSize = 12,
        ZIndex = 7,
        Parent = TabBar,
    })

    local underline = NewFrame({
        Name = "Underline",
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 1, -2),
        BackgroundColor3 = Color3.fromRGB(20, 20, 20),
        BorderSizePixel = 0,
        ZIndex = 8,
        Parent = btn,
    })

    local page = NewFrame({
        Name = name .. "Page",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Color3.fromRGB(0, 0, 0),
        BorderSizePixel = 0,
        Visible = false,
        ZIndex = 6,
        Parent = ContentArea,
    })

    local list = Instance.new("UIListLayout")
    list.Padding = UDim.new(0, 8)
    list.SortOrder = Enum.SortOrder.LayoutOrder
    list.Parent = page

    local pad = Instance.new("UIPadding")
    pad.PaddingTop = UDim.new(0, 12)
    pad.PaddingBottom = UDim.new(0, 12)
    pad.PaddingLeft = UDim.new(0, 12)
    pad.PaddingRight = UDim.new(0, 12)
    pad.Parent = page

    tabBtns[name] = btn
    tabs[name] = page

    btn.MouseButton1Click:Connect(function()
        SwitchTab(name)
    end)

    return page
end

