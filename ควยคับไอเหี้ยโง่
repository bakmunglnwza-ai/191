-- RAPID FIRE LOGIC (UNLIMITED + CUSTOM)
-- ═══════════════════════════════════════════════════════════════
local firing = false
local fireLoop = nil
local fireCount = 0
local isMouseDown = false
local mouseConnection = nil
local fireConnection = nil

local RED = Color3.fromRGB(180, 0, 0)
local RED_DIM = Color3.fromRGB(40, 0, 0)

local function DoShoot()
    -- ส่ง event การยิง (จำลองการกดเมาส์)
    if selectedMouseBtn == 0 then
        VirtualInput:SendMouseButtonEvent(0, 0, 0, true, Enum.UserInputType.MouseButton1, 1)
        task.wait(0.001)
        VirtualInput:SendMouseButtonEvent(0, 0, 0, false, Enum.UserInputType.MouseButton1, 1)
    else
        VirtualInput:SendMouseButtonEvent(0, 0, 0, true, Enum.UserInputType.MouseButton2, 1)
        task.wait(0.001)
        VirtualInput:SendMouseButtonEvent(0, 0, 0, false, Enum.UserInputType.MouseButton2, 1)
    end
    fireCount = fireCount + 1
    FireCounterLabel.Text = "ยิงไปแล้ว: " .. fireCount .. " ครั้ง"
end

local function StartFiring()
    if firing then return end
    firing = true
    
    fireCount = 0
    FireCounterLabel.Text = "ยิงไปแล้ว: 0 ครั้ง"
    
    if selectedMode == "unlimited" then
        -- โหมดไม่จำกัด - ยิงเร็วที่สุดเท่าที่จะทำได้
        FireStatusLabel.Text = "กำลังยิง (ไม่จำกัด)..."
        FireInfoLabel.Text = "@ MAX SPEED"
        FireStatusDot.BackgroundColor3 = RED
        
        fireConnection = RunService.Heartbeat:Connect(function()
            if firing then
                DoShoot()
            end
        end)
    else
        -- โหมดกำหนดเอง
        local rate = tonumber(customRateBox.Text) or 100
        if rate < 1 then rate = 1 end
        if rate > 1000000 then rate = 1000000 end
        
        FireStatusLabel.Text = "กำลังยิง..."
        FireInfoLabel.Text = "@ " .. rate .. " ครั้ง/วินาที"
        FireStatusDot.BackgroundColor3 = RED
        
        local interval = 1 / rate
        
        fireLoop = task.spawn(function()
            while firing do
                local startTime = tick()
                DoShoot()
                local elapsed = tick() - startTime
                local waitTime = interval - elapsed
                if waitTime > 0 then
                    task.wait(waitTime)
                else
                    task.wait(0)
                end
            end
        end)
    end
end

local function StopFiring()
    firing = false
    
    if fireConnection then
        fireConnection:Disconnect()
        fireConnection = nil
    end
    
    if fireLoop then
        task.cancel(fireLoop)
        fireLoop = nil
    end
    
    FireBtn.Text = "▶ เริ่มยิง"
    FireBtn.BackgroundColor3 = Color3.fromRGB(13, 13, 13)
    FireStatusDot.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    FireStatusLabel.Text = "หยุดยิง"
    FireStatusLabel.TextColor3 = Color3.fromRGB(60, 60, 60)
    FireInfoLabel.Text = ""
end

FireBtn.MouseButton1Click:Connect(function()
    if firing then
        StopFiring()
    else
        StartFiring()
        FireBtn.Text = "⏹ หยุดยิง"
        FireBtn.BackgroundColor3 = RED_DIM
        FireStatusLabel.TextColor3 = RED
    end
end)

